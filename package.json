{
  "name": "deadlight",
  "version": "1.0.0",
  "description": "Browser-based top-down co-op zombie survival with Hades-like combat feel and a dark, claustrophobic atmosphere. 1–4 players, P2P (WebRTC), waves of zombies and mini-bosses, loot, and an arsenal from pistol to chainsaw.",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sunayagiz/deadlight.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "bugs": {
    "url": "https://github.com/sunayagiz/deadlight/issues"
  },
  "homepage": "https://github.com/sunayagiz/deadlight#readme",
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
